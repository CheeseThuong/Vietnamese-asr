# ============================================================
# VietASR Pro - Cấu hình biến môi trường (MẪU)
# Sao chép file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên git (đã có trong .gitignore)
# ============================================================

# === Google Gemini API ===
# Lấy API key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Model Gemini sử dụng (mặc định: gemini-2.5-flash-lite, tiết kiệm chi phí)
# Các lựa chọn: gemini-2.5-flash-lite | gemini-2.5-flash | gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash-lite

# Bật/tắt Gemini (true/false)
# false = không gọi Gemini, chỉ dùng Wav2Vec2 ASR
USE_GEMINI=false

# === Chế độ Live Recording mặc định ===
# browser = Web Speech API (nhanh, phù hợp demo)
# wav2vec2 = mô hình nghiên cứu cục bộ (chậm hơn trên CPU)
DEFAULT_LIVE_MODE=wav2vec2

# === Động cơ ASR Nhận diện Real-time tại Backend ===
# Backend realtime ASR is local-only. Gemini is only used by /api/summarize.
REALTIME_ASR_ENGINE=wav2vec2

# === Flask Server ===
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# === HuggingFace (tuỳ chọn) ===
# Cần thiết nếu dùng model private hoặc dataset giới hạn
# HUGGINGFACE_TOKEN=hf_your_token_here

# === Cấu hình ASR Model (tuỳ chọn) ===
# ASR_MODEL_SOURCE=CheeseThuong/wav2vec2-vietnamese-asr

# === Render / Production ===
# PORT=5000
# FLASK_DEBUG=0

# ═══════════════════════════════════════════════════
# .gitignore for VietASR Pro
# ═══════════════════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual Environment ──
venv/
env/
ENV/
env.bak/
venv.bak/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter Notebook ──
.ipynb_checkpoints

# ── Sensitive / Credentials ──
token/
certs/
.env
*.env

# ── Model files (large, gitignored) ──
final_model/
*.safetensors
*.bin
*.pt
*.pth
*.onnx
models/

# ── Old checkpoints ──
results/checkpoints/

# ── Data files (raw audio, large) ──
data/raw/
Data/
processed_data/
processed_data_merged/
processed_data_vlsp/
kaggle_output/
*.wav
*.mp3
*.flac
*.ogg
*.m4a

# ── Language models ──
language_models/
*.arpa
*.klm

# ── Logs ──
logs/
runs/
*.log
tensorboard/

# ── Tools (ffmpeg, etc.) ──
tools/

# ── Temporary files ──
*.tmp
temp/
tmp/
.cache/
~$*.docx
docs/



# ── Compressed files ──
*.zip
*.tar.gz
*.rar
*.7z

# ── Keep structure files ──
!data/raw/.gitkeep
!results/.gitkeep
!tests/.gitkeep
!notebooks/.gitkeep
